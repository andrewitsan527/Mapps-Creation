# Local PostgreSQL (pgAdmin / Windows install) — no Docker required
# Create a database named "mapps" in pgAdmin, then set your password below.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/Mapps_Creation?schema=public"

# AWS / Docker Compose later:
# DATABASE_URL="postgresql://mapps:mapps@db:5432/mapps?schema=public"

AUTH_SECRET="change-me-to-a-long-random-string"
WHATSAPP_PROVIDER="stub"
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="change-me-cron-secret"
