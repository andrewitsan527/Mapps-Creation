# --- Database (required) ---
# Vercel serverless cannot reach localhost. Use a hosted Postgres
# (Vercel Postgres / Neon / Supabase).
# DATABASE_URL = pooled connection (used by the app at runtime).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# DATABASE_URL_UNPOOLED = direct connection (used by prisma migrate deploy).
DATABASE_URL_UNPOOLED="postgresql://user:password@direct-host/dbname?sslmode=require"

# --- Auth ---
# Use a long random string in production (>= 32 chars).
AUTH_SECRET="change-me-to-a-long-random-secret"

# --- WhatsApp Business API (Meta Cloud API) ---
# stub = log only | meta = live Graph API sends
WHATSAPP_PROVIDER="stub"
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v21.0"
# text = send composed message body (good for testing)
# template = send approved Meta templates (production business-initiated)
WHATSAPP_SEND_MODE="text"
WHATSAPP_TEMPLATE_LANG="en"
# Optional overrides for approved template names in Meta Business Manager
WHATSAPP_TEMPLATE_GREY_PURCHASE_ORDER="grey_purchase_order"
WHATSAPP_TEMPLATE_MILL_PROGRAM="mill_program"
WHATSAPP_TEMPLATE_SALE_BILL="sale_bill"
WHATSAPP_TEMPLATE_PROVISIONAL_BILL="provisional_bill"
WHATSAPP_TEMPLATE_QC_RETURN="qc_return"
WHATSAPP_TEMPLATE_PAYMENT_REMINDER="payment_reminder"

# --- App ---
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# --- Cron (payment reminders) ---
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically.
CRON_SECRET="change-me-cron-secret"

# --- Uploads ---
# Set on Vercel to store marka photos in Blob storage (serverless FS is read-only).
# Leave empty locally to use public/uploads instead.
BLOB_READ_WRITE_TOKEN=""
